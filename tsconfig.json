{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "allowJs": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@backend/*": ["backend/src/*"]
    },
    "types": ["node", "bun"]
  },
  "include": ["api/**/*.ts", "backend/src/**/*.ts", "admin/src/**/*.ts", "frontend/src/**/*.ts"],
  "exclude": ["node_modules"]
}
