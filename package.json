{
  "name": "gusshair",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev:backend": "cd backend && bun run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:admin": "cd admin && npm run dev -- --port 5174",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:admin\"",
    "build": "npm run build:frontend && npm run build:admin && npm run build:move",
    "build:frontend": "npm run build -w frontend",
    "build:admin": "npm run build -w admin",
    "build:move": "node -e \"const fs=require('fs');const path=require('path');fs.mkdirSync('dist/admin',{recursive:true});fs.cpSync('frontend/dist','dist',{recursive:true});fs.cpSync('admin/dist','dist/admin',{recursive:true});\"",
    "start": "cd backend && bun run src/index.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "workspaces": [
    "frontend",
    "admin",
    "backend"
  ],
  "devDependencies": {
    "@types/node": "^22.13.9",
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "@hono/trpc-server": "^0.4.2",
    "@trpc/server": "^11.16.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.10",
    "jose": "^6.2.2",
    "pg": "^8.20.0",
    "uploadthing": "^7.7.4",
    "zod": "^4.3.6"
  }
}
